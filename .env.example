# Rahmah HMS Environment Configuration

# Database Configuration (Required for Production)
DATABASE_URL=your_postgresql_database_url_here

# Clerk Authentication (Optional - System runs in demo mode without these)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key_here
CLERK_SECRET_KEY=your_secret_key_here

# Demo Mode
# When Clerk keys are not configured, the system runs in demo mode
# This allows you to test all features without setting up authentication